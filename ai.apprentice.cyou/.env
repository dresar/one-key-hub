# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_SELF_REGISTRATION=false
EXPOSE_METRICS=false
EXPOSE_OPENAPI=true
ALLOW_CREDENTIAL_EXPORT=false
ENABLE_INTERNAL_TEST_ROUTES=false
EXPOSE_KEY_PLAINTEXT=true
REVOKE_TOKENS_IN_DB=true

# ─── Rate Limiting & Timeouts ────────────────────────────────────────────────
API_KEY_CACHE_TTL_MS=2000
HMAC_MAX_SKEW_MS=30000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_DEFAULT=200
API_KEY_GRACE_MS=60000
BREAKER_TIMEOUT_MS=8000
BREAKER_HALF_OPEN_AFTER_MS=2000

# ─── Upload Limits ───────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760
MAX_PROXY_BODY_BYTES=2097152

# ─── Logging ─────────────────────────────────────────────────────────────────
GATEWAY_LOG_MODE=light

# ─── OpenClaw AI Provider ────────────────────────────────────────────────────
# Isi API key OpenClaw default (opsional — per-user pakai credential di dashboard)
OPENCLAW_DEFAULT_API_KEY=

